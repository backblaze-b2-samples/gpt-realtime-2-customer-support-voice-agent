# Backblaze B2 (required) — canonical names per parent CLAUDE.md
B2_APPLICATION_KEY_ID=your_application_key_id
B2_APPLICATION_KEY=your_application_key
B2_BUCKET_NAME=your-bucket-name
B2_REGION=your-b2-region
B2_PUBLIC_URL_BASE=

# Example of what filled-in B2 values look like (placeholders only — for shape reference):
# B2_APPLICATION_KEY_ID=<24-char hex key id from B2 dashboard>
# B2_APPLICATION_KEY=<application key shown once on creation>
# B2_BUCKET_NAME=my-app-bucket

# OpenAI (required) — used for the Realtime API + post-call summary model
OPENAI_API_KEY=your_openai_api_key
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_SUMMARY_MODEL=gpt-4.1-mini

# App
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Optional: regex of additional allowed CORS origins (dev-only escape hatch).
# Leave empty in production — only the explicit allowlist above is honored.
# Example value: ^http://localhost:\d+$
# API_CORS_ORIGIN_REGEX=

# Optional: when your B2 bucket is public, set B2_PUBLIC_URL_BASE to the
# bucket's friendly URL prefix (e.g. https://f004.backblazeb2.com/file/<bucket-name>). The API
# uses it to construct direct `url` fields in /files responses. Leave empty
# to omit direct URLs from responses (clients fall back to presigned URLs).

# Optional: max upload size (bytes) for /upload. Default 100 MiB.
# MAX_FILE_SIZE=104857600

# Optional: file path used to persist a small download counter across
# restarts. Point at a durable volume in production if you care about
# the count surviving restarts.
# DOWNLOAD_COUNT_FILE=data/download_count.json
